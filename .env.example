# ---- Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=regrag
POSTGRES_USER=regrag
POSTGRES_PASSWORD=regrag_dev_password
DATABASE_URL=postgresql://regrag:regrag_dev_password@postgres:5432/regrag

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
APP_BIND_HOST=0.0.0.0
APP_BIND_PORT=8000
INGEST_BEARER_TOKEN=replace-me-with-a-long-random-string

# ---- Embeddings ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32

# ---- Reranker ----
# RERANKER_PROVIDER: local | cohere
RERANKER_PROVIDER=local
RERANKER_MODEL=BAAI/bge-reranker-base
COHERE_API_KEY=

# ---- LLM Provider ----
# LLM_PROVIDER: anthropic | openai | deepinfra
LLM_PROVIDER=anthropic

# Anthropic Claude (default)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepInfra — OpenAI-compatible endpoint serving DeepSeek, Llama, Qwen, …
# Get a key at https://deepinfra.com/dash/api_keys.
# Some good model choices (case-sensitive, full repo path):
#   - deepseek-ai/DeepSeek-V3            (default; supports JSON mode)
#   - deepseek-ai/DeepSeek-V3.1
#   - meta-llama/Meta-Llama-3.1-70B-Instruct
DEEPINFRA_API_KEY=
DEEPINFRA_MODEL=deepseek-ai/DeepSeek-V3
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60

# ---- Retrieval tuning ----
BM25_TOP_K=50
VECTOR_TOP_K=50
RRF_K=60
RERANK_TOP_K=30
ANSWER_TOP_K=5
MIN_RERANK_SCORE=0.0

# ---- Chunking ----
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
CHUNK_MIN_TOKENS=80

# ---- Frontend (web) ----
# Baked into the client bundle at docker build time. From the browser's
# perspective the FastAPI is reachable at the host port published by the api
# service. Override for non-localhost deployments.
NEXT_PUBLIC_API_URL=http://localhost:8000
